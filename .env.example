# App
APP_NAME=Job Portal API

# Security
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite+aiosqlite:///./job_portal.db

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Email / OTP
OTP_EXPIRE_MINUTES=10
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yourname@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=yourname@gmail.com
SMTP_FROM_NAME=HOT CV
SMTP_USE_TLS=true
SMTP_DEBUG=true